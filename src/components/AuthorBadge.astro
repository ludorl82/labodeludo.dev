---
import type { Author } from "../lib/author";

interface Props {
  author: Author;
}

const { author } = Astro.props;
const AVATAR: Record<Author, string> = {
  bob: "/images/bob-avatar.png",
  ludo: "/images/ludo-avatar.png",
};
---

<span class="author" class:list={[author]}>
  <img src={AVATAR[author]} alt="" width="16" height="16" />
  {author}
</span>

<style>
  .author {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
  }

  .author img {
    border-radius: 3px;
    display: block;
  }

  .author.bob {
    color: var(--accent-labo);
  }
</style>
