---
interface Props {
  lang?: "fr" | "en";
}

const { lang = "fr" } = Astro.props;

const shortcuts =
  lang === "en"
    ? [
        ["j / k", "move between posts"],
        ["gg / G", "jump to top / bottom"],
        ["Enter", "open focused post"],
        ["Esc", "clear focus / close this"],
        ["?", "toggle this cheat sheet"],
      ]
    : [
        ["j / k", "se déplacer entre les articles"],
        ["gg / G", "aller en haut / en bas"],
        ["Entrée", "ouvrir l'article ciblé"],
        ["Échap", "annuler le focus / fermer ceci"],
        ["?", "afficher / masquer cette aide"],
      ];

const title = lang === "en" ? "Keyboard shortcuts" : "Raccourcis clavier";
---

<div id="keyboard-help" class="keyboard-help" hidden>
  <div class="keyboard-help-panel">
    <p class="keyboard-help-title">$ {title.toLowerCase().replace(/ /g, "_")} --help</p>
    <dl>
      {
        shortcuts.map(([key, desc]) => (
          <div class="row">
            <dt>{key}</dt>
            <dd>{desc}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</div>

<div id="sudo-toast" class="sudo-toast" hidden></div>

<style>
  .keyboard-help {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4vh 4vw;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(2px);
  }

  .keyboard-help[hidden] {
    display: none;
  }

  .keyboard-help-panel {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    max-width: 24rem;
    width: 100%;
    font-family: var(--font-mono);
  }

  .keyboard-help-title {
    margin: 0 0 1rem;
    color: var(--accent-live);
    font-size: 0.875rem;
  }

  dl {
    margin: 0;
  }

  .row {
    display: flex;
    gap: 1rem;
    padding: 0.4rem 0;
    border-top: 1px solid var(--panel-border);
  }

  .row:first-child {
    border-top: none;
  }

  dt {
    flex: 0 0 6rem;
    color: var(--text);
    font-weight: 600;
    font-size: 0.8125rem;
  }

  dd {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.8125rem;
  }

  .sudo-toast {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 250;
    max-width: 22rem;
    background: var(--panel);
    border: 1px solid var(--accent-live);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text);
    white-space: pre-line;
    box-shadow: 0 4px 24px rgb(0 0 0 / 0.6);
  }

  .sudo-toast[hidden] {
    display: none;
  }

  @keyframes sudo-glitch {
    0%,
    100% {
      filter: none;
    }
    25%,
    75% {
      filter: invert(1);
    }
  }

  :global(body.sudo-glitch) {
    animation: sudo-glitch 0.5s steps(2, end);
  }
</style>

<script define:vars={{ lang }}>
  const help = document.getElementById("keyboard-help");
  const toast = document.getElementById("sudo-toast");

  function toggleHelp() {
    help.hidden = !help.hidden;
  }

  document.addEventListener("keydown", (e) => {
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const tag = document.activeElement?.tagName;
    if (tag === "INPUT" || tag === "TEXTAREA") return;

    if (e.key === "?") {
      e.preventDefault();
      toggleHelp();
    } else if (e.key === "Escape" && !help.hidden) {
      help.hidden = true;
    }
  });

  help.addEventListener("click", (e) => {
    if (e.target === help) help.hidden = true;
  });

  const KONAMI = [
    "arrowup",
    "arrowup",
    "arrowdown",
    "arrowdown",
    "arrowleft",
    "arrowright",
    "arrowleft",
    "arrowright",
    "b",
    "a",
  ];
  let progress = 0;
  let toastTimer;

  document.addEventListener("keydown", (e) => {
    const key = e.key.toLowerCase();
    progress = key === KONAMI[progress] ? progress + 1 : key === KONAMI[0] ? 1 : 0;

    if (progress === KONAMI.length) {
      progress = 0;
      const message =
        lang === "en"
          ? "$ sudo su -\n[sudo] password for ludo: ********\nroot access granted (5s, don't tell ludo)"
          : "$ sudo su -\n[sudo] mot de passe pour ludo : ********\nAccès root accordé (5s, ne le dites pas à ludo)";
      toast.textContent = message;
      toast.hidden = false;
      document.body.classList.add("sudo-glitch");
      window.clearTimeout(toastTimer);
      window.setTimeout(() => document.body.classList.remove("sudo-glitch"), 500);
      toastTimer = window.setTimeout(() => {
        toast.hidden = true;
      }, 5000);
    }
  });
</script>
