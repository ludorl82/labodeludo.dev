---
interface Props {
  context?: "article" | "architecture";
  lang?: "fr" | "en";
}

const { context = "article", lang = "fr" } = Astro.props;

const copy = {
  fr: {
    ariaLabel:
      "Schéma : avant, un seul hôte conteneurs Docker faisait tourner tous les services ; après, une grappe k3s de six nœuds répartit la même charge entre un plan de contrôle dans le nuage et des nœuds à la maison. Le bastion, séparé de la grappe, orchestre des sauvegardes chiffrées de chaque nœud chaque semaine, la nuit.",
    avant: "avant · hôte conteneurs unique (Docker)",
    single: "hôte conteneurs",
    singleSub: "(Docker, un seul nœud)",
    apres: "après · grappe k3s (6 nœuds)",
    controlPlane: "plan de contrôle",
    controlPlaneSub: "(cloud)",
    node: "nœud",
    nodeSub1: "(maison, Raspberry Pi)",
    nodeSub2: "(maison, VM)",
    bastion: "bastion",
    bastionSub: "(console)",
    backupLine1: "sauvegardes chiffrées",
    backupLine2: "chaque semaine, la nuit — via Claude Code",
  },
  en: {
    ariaLabel:
      "Diagram: before, a single Docker container host ran every service; after, a six-node k3s cluster spreads the same workload across a cloud control plane and home nodes. The bastion, separate from the cluster, orchestrates encrypted backups of every node weekly, at night.",
    avant: "before · single container host (Docker)",
    single: "container host",
    singleSub: "(Docker, single node)",
    apres: "after · k3s cluster (6 nodes)",
    controlPlane: "control plane",
    controlPlaneSub: "(cloud)",
    node: "node",
    nodeSub1: "(home, Raspberry Pi)",
    nodeSub2: "(home, VM)",
    bastion: "bastion",
    bastionSub: "(console)",
    backupLine1: "encrypted backups",
    backupLine2: "weekly, at night — via Claude Code",
  },
} as const;

const t = copy[lang];
---

<figure class="k3s-diagram">
  <div class="diagram-wrap">
    <svg viewBox="0 0 760 400" role="img" aria-label={t.ariaLabel}>
      <defs>
        <marker id="k3s-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="var(--text-faint)" />
        </marker>
        <marker id="k3s-arrow-live" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="var(--accent-live)" />
        </marker>
      </defs>

      <!-- avant : hôte conteneurs unique -->
      <text x="380" y="28" text-anchor="middle" font-family="var(--font-mono)" font-size="12" fill="var(--text-faint)">{t.avant}</text>
      <rect x="290" y="38" width="180" height="55" rx="6" fill="var(--panel)" stroke="var(--panel-border)" stroke-width="1.5" />
      <text x="380" y="61" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--text)">{t.single}</text>
      <text x="380" y="78" text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" fill="var(--text-faint)">{t.singleSub}</text>

      <path d="M380,93 V118" fill="none" stroke="var(--accent-live)" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#k3s-arrow-live)" />

      <!-- après : grappe k3s -->
      <text x="380" y="140" text-anchor="middle" font-family="var(--font-mono)" font-size="12" fill="var(--accent-live)">{t.apres}</text>

      <rect x="290" y="150" width="180" height="55" rx="6" fill="var(--panel)" stroke="var(--accent-live)" stroke-width="1.5" />
      <text x="380" y="173" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--text)">{t.controlPlane}</text>
      <text x="380" y="190" text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" fill="var(--text-faint)">{t.controlPlaneSub}</text>

      <g fill="none" stroke="var(--accent-live)" stroke-width="1.5" stroke-dasharray="4 3">
        <path d="M330,205 V225 H120 V245" marker-end="url(#k3s-arrow-live)" />
        <path d="M380,205 V245" marker-end="url(#k3s-arrow-live)" />
        <path d="M430,205 V225 H640 V245" marker-end="url(#k3s-arrow-live)" />
      </g>

      <!-- 3 groupes de nœuds représentant les 5 nœuds maison -->
      <rect x="40" y="245" width="160" height="55" rx="6" fill="var(--panel)" stroke="var(--panel-border)" stroke-width="1.5" />
      <text x="120" y="268" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--text)">{t.node} × 2</text>
      <text x="120" y="285" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--text-faint)">{t.nodeSub1}</text>

      <rect x="300" y="245" width="160" height="55" rx="6" fill="var(--panel)" stroke="var(--panel-border)" stroke-width="1.5" />
      <text x="380" y="268" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--text)">{t.node} × 3</text>
      <text x="380" y="285" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--text-faint)">{t.nodeSub2}</text>

      <rect x="560" y="245" width="160" height="55" rx="6" fill="var(--panel)" stroke="var(--panel-border)" stroke-width="1.5" />
      <text x="640" y="268" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--text)">{t.node}</text>
      <text x="640" y="285" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--text-faint)">{t.nodeSub2}</text>

      <!-- bastion + sauvegardes -->
      <rect x="290" y="330" width="180" height="50" rx="6" fill="none" stroke="var(--accent-live)" stroke-width="1.5" stroke-dasharray="4 3" />
      <text x="380" y="351" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--accent-live)">{t.bastion}</text>
      <text x="380" y="367" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--accent-live)">{t.bastionSub}</text>

      <g fill="none" stroke="var(--accent-live)" stroke-width="1.5" stroke-dasharray="3 3">
        <path d="M120,300 V318 H290 V344" marker-end="url(#k3s-arrow-live)" />
        <path d="M640,300 V318 H470 V344" marker-end="url(#k3s-arrow-live)" />
      </g>

      <text x="620" y="335" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--accent-live)">{t.backupLine1}</text>
      <text x="620" y="349" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--accent-live)">{t.backupLine2}</text>
    </svg>
  </div>
  <figcaption>
    {
      context === "architecture" ? (
        lang === "en" ? (
          <>
            Detail of the <a href="/inventaire/hote-conteneurs/">container cluster</a> and{" "}
            <a href="/inventaire/bastion/">bastion</a> roles: the single Docker host became a small k3s cluster
            split between a cloud control plane and home nodes, and the bastion now runs weekly, nighttime encrypted
            backups of every node. See the article:{" "}
            <a href="/blog/deployer-un-cluster-k3s-avec-claude-code/">building a k3s cluster with Claude Code</a>.
          </>
        ) : (
          <>
            Détail des rôles <a href="/inventaire/hote-conteneurs/">grappe conteneurs</a> et{" "}
            <a href="/inventaire/bastion/">bastion</a> : l'hôte Docker unique est devenu une petite grappe k3s
            répartie entre un plan de contrôle dans le nuage et des nœuds à la maison, et le bastion orchestre
            désormais des sauvegardes chiffrées de chaque nœud chaque semaine, la nuit. Voir l'article :{" "}
            <a href="/blog/deployer-un-cluster-k3s-avec-claude-code/">bâtir une grappe k3s avec Claude Code</a>.
          </>
        )
      ) : lang === "en" ? (
        <>
          Before/after: from a single Docker host to a six-node k3s cluster split between the cloud and home. See
          the <a href="/architecture/">architecture overview</a>.
        </>
      ) : (
        <>
          Avant/après : d'un hôte Docker unique à une grappe k3s de six nœuds répartie entre le nuage et la maison.
          Voir la <a href="/architecture/">vue d'ensemble de l'architecture</a>.
        </>
      )
    }
  </figcaption>
</figure>

<style>
  .k3s-diagram {
    margin: 2rem 0;
  }

  .diagram-wrap {
    overflow-x: auto;
    border: 1px solid var(--panel-border);
    border-radius: 8px;
    background: var(--bg);
    padding: 1rem;
  }

  svg {
    display: block;
    width: 100%;
    min-width: 560px;
    height: auto;
  }

  figcaption {
    margin-top: 0.75rem;
    max-width: var(--measure);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-faint);
    line-height: 1.6;
  }

  figcaption a {
    color: var(--accent-live);
  }
</style>
