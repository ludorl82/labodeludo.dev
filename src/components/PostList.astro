---
import CategoryChip from "./CategoryChip.astro";
import AuthorBadge from "./AuthorBadge.astro";
import { primaryCategory } from "../lib/category";
import { authorFromTags } from "../lib/author";

interface Props {
  posts: { id: string; data: { title: string; description?: string; pubDate: Date; tags: string[] } }[];
  basePath?: string;
  lang?: "fr" | "en";
}

const { posts, basePath = "/blog", lang = "fr" } = Astro.props;
const dateLocale = lang === "en" ? "en-CA" : "fr-CA";
const emptyMessage =
  lang === "en"
    ? `$ ls ${basePath}/\nls: no matches found`
    : `$ ls ${basePath}/\nls: aucune correspondance trouvée`;
---

{
  posts.length === 0 ? (
    <pre class="empty"><code>{emptyMessage}</code></pre>
  ) : (
    <ul class="list">
      {posts.map((post) => (
        <li class="row">
          <a class="row-link" href={`${basePath}/${post.id}/`}>
            <div class="row-meta">
              <CategoryChip category={primaryCategory(post.data.tags)} />
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(dateLocale)}
              </time>
              <AuthorBadge author={authorFromTags(post.data.tags)} />
            </div>
            <h2 class="row-title">{post.data.title}</h2>
            {post.data.description && <p class="row-desc">{post.data.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    border-top: 1px solid var(--panel-border);
  }

  .row {
    border-bottom: 1px solid var(--panel-border);
  }

  .row-link {
    display: block;
    padding: 1.5rem 0.75rem;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.15s ease;
  }

  .row-link:hover,
  .row-link:focus-visible {
    background: var(--panel);
  }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-faint);
  }

  .row-title {
    margin: 0.6rem 0 0;
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.005em;
  }

  .row-desc {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    max-width: var(--measure);
    font-size: 0.9375rem;
  }

  .empty {
    margin: 1rem 0 0;
    padding: 1rem 1.25rem;
    background: var(--panel);
    border: 1px solid var(--panel-border);
    border-left: 3px solid var(--panel-border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-faint);
    line-height: 1.6;
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".list .row-link"));

  if (links.length) {
    function focusAt(index: number) {
      const clamped = Math.max(0, Math.min(index, links.length - 1));
      links[clamped].focus();
      links[clamped].scrollIntoView({ block: "nearest" });
    }

    let pendingG = false;
    let pendingGAt = 0;

    document.addEventListener("keydown", (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (document.activeElement as HTMLElement | null)?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA") return;

      const current = links.indexOf(document.activeElement as HTMLAnchorElement);

      if (e.key === "g") {
        if (pendingG && Date.now() - pendingGAt < 500) {
          e.preventDefault();
          focusAt(0);
          pendingG = false;
        } else {
          pendingG = true;
          pendingGAt = Date.now();
        }
        return;
      }

      pendingG = false;

      if (e.key === "j") {
        e.preventDefault();
        focusAt(current + 1);
      } else if (e.key === "k") {
        e.preventDefault();
        focusAt(current === -1 ? links.length - 1 : current - 1);
      } else if (e.key === "G") {
        e.preventDefault();
        focusAt(links.length - 1);
      } else if (e.key === "Escape") {
        (document.activeElement as HTMLElement | null)?.blur();
      }
    });
  }
</script>
