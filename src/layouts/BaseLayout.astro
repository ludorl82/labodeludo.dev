---
import "../styles/global.css";
import Lightbox from "../components/Lightbox.astro";

interface Props {
  title: string;
  description?: string;
  lang?: "fr" | "en";
}

const { title, description, lang = "fr" } = Astro.props;

const homeHref = lang === "en" ? "/en/" : "/";
const tagline =
  lang === "en"
    ? "homelab & personal infra, in public"
    : "homelab & infra personnelle, en public";
const footerLine =
  lang === "en"
    ? "Le labo de Ludo — the journal of our experiments at home."
    : "Le labo de Ludo — le journal de nos expérimentations à la maison.";

const navItems =
  lang === "en"
    ? [{ href: "/", label: "Français" }]
    : [
        { href: "/mission/", label: "Mission" },
        { href: "/architecture/", label: "Architecture" },
        { href: "/inventaire/", label: "Inventaire" },
        { href: "/auteurs/", label: "Auteurs" },
      ];
navItems.push({ href: "https://github.com/ludorl82", label: "GitHub" });
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <a class="wordmark" href={homeHref}>
          <span class="wordmark-prompt">ludo@labo</span><span class="wordmark-sep">:~$</span>
        </a>
        <p class="tagline">{tagline}</p>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>
          {footerLine}
        </p>
        <nav class="footer-nav">
          {
            navItems.map((item, i) => (
              <>
                <span class:list={["seg", i % 2 === 0 ? "seg-a" : "seg-b"]}>
                  <a href={item.href}>{item.label}</a>
                </span>
                <span
                  class:list={[
                    "arrow",
                    i % 2 === 0 ? "arrow-a" : "arrow-b",
                    i === navItems.length - 1 && "arrow-end",
                  ]}
                  aria-hidden="true"
                />
              </>
            ))
          }
        </nav>
      </footer>
    </div>

    <Lightbox />
  </body>
</html>

<style>
  .page {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  .site-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--panel-border);
  }

  .wordmark {
    display: inline-flex;
    align-items: baseline;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.375rem;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .wordmark-prompt {
    color: var(--text);
  }

  .wordmark-sep {
    color: var(--accent-live);
    margin-left: 2px;
  }

  .tagline {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .site-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--panel-border);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .site-footer p {
    margin: 0;
  }

  .footer-nav {
    --seg-a: #1c1c1c;
    --seg-b: #2a2a2a;
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .seg {
    display: flex;
    align-items: center;
    padding: 0.35em 0.85em;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .seg a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .seg-a {
    background: var(--seg-a);
  }

  .seg-b {
    background: var(--seg-b);
  }

  .seg:hover {
    background: var(--accent-live);
  }

  .seg:hover a {
    color: var(--bg);
  }

  /* Powerline-style slanted separators, using the Powerline glyph range
     already bundled in the self-hosted Hack Nerd Font. */
  .arrow {
    display: flex;
    align-items: center;
    font-family: "Hack Nerd Font Mono", monospace;
    line-height: 1;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .arrow::before {
    content: "\e0b0";
  }

  .arrow-a {
    color: var(--seg-a);
    background: var(--seg-b);
  }

  .arrow-b {
    color: var(--seg-b);
    background: var(--seg-a);
  }

  .arrow-end {
    background: transparent;
  }

  /* Let the hover color bleed into the neighboring arrows, so the
     highlight reads as one continuous slanted segment. */
  .seg:hover + .arrow {
    color: var(--accent-live);
  }

  .arrow:has(+ .seg:hover) {
    background: var(--accent-live);
  }
</style>
