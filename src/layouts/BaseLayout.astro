---
import "../styles/global.css";
import Lightbox from "../components/Lightbox.astro";
import EasterEggs from "../components/EasterEggs.astro";
import { resolveOgImage } from "../lib/ogImage";

interface Props {
  title: string;
  description?: string;
  lang?: "fr" | "en";
  heroImage?: string;
}

const { title, description, lang = "fr", heroImage } = Astro.props;

const ogImageUrl = new URL(resolveOgImage(heroImage), Astro.site).toString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const homeHref = lang === "en" ? "/en/" : "/";
const tagline =
  lang === "en"
    ? "homelab & personal infra, in public"
    : "homelab & infra personnelle, en public";
const footerLine =
  lang === "en"
    ? "Le labo de Ludo — the journal of our experiments at home."
    : "Le labo de Ludo — le journal de nos expérimentations à la maison.";

const navItems =
  lang === "en"
    ? [{ href: "/", label: "Français" }]
    : [
        { href: "/mission/", label: "Mission" },
        { href: "/architecture/", label: "Architecture" },
        { href: "/inventaire/", label: "Inventaire" },
        { href: "/auteurs/", label: "Auteurs" },
      ];
navItems.push({ href: "https://github.com/ludorl82", label: "GitHub" });
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline>
      // Some in-app browsers (LinkedIn, Instagram, etc.) render the first
      // paint of a freshly-opened link at a stale desktop viewport width and
      // only recompute layout on an explicit reload. Nudging the viewport
      // meta's initial-scale forces those WebViews to re-layout immediately.
      (function () {
        if (document.documentElement.clientWidth <= screen.width * 1.5) return;
        var vp = document.querySelector('meta[name="viewport"]');
        if (!vp) return;
        vp.setAttribute("content", "width=device-width, initial-scale=1.0001");
        requestAnimationFrame(function () {
          vp.setAttribute("content", "width=device-width, initial-scale=1");
        });
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <a class="wordmark" href={homeHref}>
          <span class="wordmark-prompt">ludo@labo</span><span class="wordmark-sep">:~$</span>
        </a>
        <p class="tagline">{tagline}</p>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>
          {footerLine}
        </p>
        <nav class="footer-nav">
          {
            navItems.map((item, i) => (
              <>
                <span class:list={["seg", i % 2 === 0 ? "seg-a" : "seg-b"]}>
                  <a href={item.href}>{item.label}</a>
                </span>
                <span
                  class:list={[
                    "arrow",
                    i % 2 === 0 ? "arrow-a" : "arrow-b",
                    i === navItems.length - 1 && "arrow-end",
                  ]}
                  aria-hidden="true"
                />
              </>
            ))
          }
        </nav>
        <p class="kbd-hint">
          {lang === "en"
            ? "Tip: press ? for keyboard shortcuts."
            : "Astuce : appuyez sur ? pour les raccourcis clavier."}
        </p>
      </footer>
    </div>

    <Lightbox />
    <EasterEggs lang={lang} homeHref={homeHref} navItems={navItems} />
  </body>
</html>

<style>
  .page {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  .site-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--panel-border);
  }

  .wordmark {
    display: inline-flex;
    align-items: baseline;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.375rem;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .wordmark-prompt {
    color: var(--text);
  }

  .wordmark-sep {
    color: var(--accent-live);
    margin-left: 2px;
  }

  .tagline {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .site-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--panel-border);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .site-footer p {
    margin: 0;
  }

  .footer-nav {
    --seg-a: #1c1c1c;
    --seg-b: #2a2a2a;
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .site-footer .kbd-hint {
    margin-top: 0.85rem;
    color: var(--text-faint);
  }

  .seg {
    display: flex;
    align-items: center;
    padding: 0.35em 0.85em;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .seg a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .seg-a {
    background: var(--seg-a);
  }

  .seg-b {
    background: var(--seg-b);
  }

  .seg:hover {
    background: var(--accent-live);
  }

  .seg:hover a {
    color: var(--bg);
  }

  /* Powerline-style slanted separators. A clip-path triangle (rather than
     the Powerline font glyph) guarantees the arrow always fills the exact
     height of its segment, regardless of font metrics. */
  .arrow {
    position: relative;
    width: 0.6em;
    align-self: stretch;
    transition: background-color 0.15s ease;
  }

  .arrow::before {
    content: "";
    position: absolute;
    inset: 0;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    transition: background-color 0.15s ease;
  }

  .arrow-a {
    background: var(--seg-b);
  }

  .arrow-a::before {
    background: var(--seg-a);
  }

  .arrow-b {
    background: var(--seg-a);
  }

  .arrow-b::before {
    background: var(--seg-b);
  }

  .arrow-end {
    background: transparent;
  }

  /* Let the hover color bleed into the neighboring arrows, so the
     highlight reads as one continuous slanted segment. */
  .seg:hover + .arrow::before {
    background: var(--accent-live);
  }

  .arrow:has(+ .seg:hover) {
    background: var(--accent-live);
  }
</style>
