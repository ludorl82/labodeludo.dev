---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Architecture — Le labo de Ludo"
  description="Vue d'ensemble du homelab : réseau, tunnel chiffré, VLANs et rôles des serveurs."
>
  <a class="back" href="/">&larr; tous les articles</a>

  <header class="page-header">
    <h1>Architecture</h1>
    <p class="subtitle">
      Vue d'ensemble du réseau — noms et adresses fictifs (préfixe de
      documentation <code>2001:db8:.../64</code>, RFC 3849), l'idée est de
      montrer la forme du réseau, pas le détail réel.
    </p>
  </header>

  <div class="diagram-wrap">
    <svg
      class="diagram"
      viewBox="0 0 1100 850"
      role="img"
      aria-label="Diagramme d'architecture : deux fournisseurs Internet reliés respectivement à un pare-feu domicile et à une VM cloud, connectés entre eux par un tunnel chiffré ; le pare-feu domicile distribue vers deux VLANs (Serveurs, Réseau local) et vers des clients mobiles en VPN."
    >
      <defs>
        <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="var(--text-faint)" />
        </marker>
        <marker id="arrow-live" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="var(--accent-live)" />
        </marker>
      </defs>

      <!-- structural connectors -->
      <g class="conn" fill="none" stroke="var(--text-faint)" stroke-width="1.5">
        <path d="M200,74 L220,360" marker-end="url(#arrow)" />
        <path d="M820,74 L810,110" marker-end="url(#arrow)" />
        <path d="M220,420 L270,470" marker-end="url(#arrow)" />
        <path d="M220,420 C 400,440 620,440 750,470" marker-end="url(#arrow)" />
      </g>

      <!-- live / encrypted connectors -->
      <g class="conn-live" fill="none" stroke="var(--accent-live)" stroke-width="1.5" stroke-dasharray="5 4">
        <path d="M700,330 C 550,380 420,380 350,392" marker-end="url(#arrow-live)" />
        <path d="M350,405 C 550,470 750,500 900,545" marker-end="url(#arrow-live)" />
        <path d="M900,172 C 400,250 150,600 90,710" marker-end="url(#arrow-live)" />
        <path d="M900,190 C 500,300 250,540 100,610" marker-end="url(#arrow-live)" />
        <path d="M900,208 C 650,320 700,480 700,510" marker-end="url(#arrow-live)" />
      </g>

      <!-- connector labels -->
      <g class="conn-label" font-family="var(--font-mono)" font-size="12" fill="var(--text-faint)">
        <text x="150" y="220">WAN</text>
        <text x="835" y="95">IP publique</text>
        <text x="470" y="358">tunnel chiffré (VPN site-à-site)</text>
        <text x="705" y="475">VPN clients distants</text>
      </g>
      <g class="conn-label" font-family="var(--font-mono)" font-size="11" fill="var(--accent-live)">
        <text x="330" y="655">labo.exemple.net</text>
        <text x="330" y="565">media.exemple.net</text>
        <text x="560" y="500">assistant.exemple.net</text>
      </g>

      <!-- Internet nodes -->
      <g font-family="var(--font-mono)" font-size="13" text-anchor="middle">
        <ellipse cx="200" cy="45" rx="140" ry="35" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="200" y="41" fill="var(--text)">Internet</text>
        <text x="200" y="58" fill="var(--text-faint)" font-size="11">(FAI résidentiel)</text>

        <ellipse cx="820" cy="45" rx="150" ry="35" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="820" y="41" fill="var(--text)">Internet</text>
        <text x="820" y="58" fill="var(--text-faint)" font-size="11">(fournisseur cloud)</text>
      </g>

      <!-- Cloud VM -->
      <g>
        <rect x="620" y="110" width="380" height="225" rx="6" fill="none" stroke="var(--panel-border)" stroke-width="1.5" />
        <text x="640" y="132" font-family="var(--font-display)" font-size="13" font-weight="600" fill="var(--text)">VM cloud — relais.exemple.net</text>

        <rect x="640" y="150" width="340" height="44" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="660" y="176" font-family="var(--font-mono)" font-size="13" fill="var(--text)">proxy inverse (TLS)</text>

        <rect x="640" y="205" width="340" height="44" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="660" y="231" font-family="var(--font-mono)" font-size="13" fill="var(--text)">site web statique</text>

        <rect x="640" y="260" width="340" height="44" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="660" y="286" font-family="var(--font-mono)" font-size="13" fill="var(--text)">surveillance + alertes</text>
      </g>

      <!-- Home gateway -->
      <g>
        <rect x="90" y="360" width="260" height="60" rx="6" fill="var(--panel)" stroke="var(--panel-border)" stroke-width="1.5" />
        <text x="220" y="384" text-anchor="middle" font-family="var(--font-display)" font-size="13" font-weight="600" fill="var(--text)">pare-feu domicile</text>
        <text x="220" y="401" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-faint)">portail.exemple.net</text>
      </g>

      <!-- VLAN Serveurs -->
      <g>
        <rect x="40" y="470" width="460" height="330" rx="6" fill="none" stroke="var(--panel-border)" stroke-width="1.5" />
        <text x="60" y="494" font-family="var(--font-display)" font-size="13" font-weight="600" fill="var(--text)">VLAN — Serveurs</text>

        <rect x="60" y="510" width="420" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="80" y="535" font-family="var(--font-mono)" font-size="13" fill="var(--text)">bastion / console</text>

        <rect x="60" y="560" width="420" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="80" y="585" font-family="var(--font-mono)" font-size="13" fill="var(--text)">stockage (NAS)</text>

        <rect x="60" y="610" width="420" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="80" y="635" font-family="var(--font-mono)" font-size="13" fill="var(--text)">pipeline média</text>

        <rect x="60" y="660" width="420" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="80" y="685" font-family="var(--font-mono)" font-size="13" fill="var(--text)">calcul GPU</text>

        <rect x="60" y="710" width="420" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="80" y="735" font-family="var(--font-mono)" font-size="13" fill="var(--text)">hôte conteneurs (web)</text>
      </g>

      <!-- VLAN Réseau local -->
      <g>
        <rect x="560" y="470" width="380" height="210" rx="6" fill="none" stroke="var(--panel-border)" stroke-width="1.5" />
        <text x="580" y="494" font-family="var(--font-display)" font-size="13" font-weight="600" fill="var(--text)">VLAN — Réseau local</text>

        <rect x="580" y="510" width="340" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="600" y="535" font-family="var(--font-mono)" font-size="13" fill="var(--text)">postes personnels</text>

        <rect x="580" y="560" width="340" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="600" y="585" font-family="var(--font-mono)" font-size="13" fill="var(--text)">domotique</text>

        <rect x="580" y="610" width="340" height="40" rx="4" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="600" y="635" font-family="var(--font-mono)" font-size="13" fill="var(--text)">caméras / périphériques</text>
      </g>

      <!-- Mobile clients -->
      <g font-family="var(--font-mono)" font-size="13" text-anchor="middle">
        <ellipse cx="950" cy="545" rx="130" ry="38" fill="var(--panel)" stroke="var(--panel-border)" />
        <text x="950" y="541" fill="var(--text)">clients mobiles</text>
        <text x="950" y="558" fill="var(--text-faint)" font-size="11">(VPN)</text>
      </g>
    </svg>
  </div>

  <div class="legend">
    <span class="legend-item"><span class="swatch structural" /> liaison réseau</span>
    <span class="legend-item"><span class="swatch live" /> tunnel chiffré / routage applicatif</span>
  </div>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--accent-live);
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }

  .subtitle {
    max-width: var(--measure);
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .subtitle code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--panel);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .diagram-wrap {
    overflow-x: auto;
    border: 1px solid var(--panel-border);
    border-radius: 8px;
    background: var(--bg);
    padding: 1rem;
  }

  .diagram {
    display: block;
    width: 100%;
    min-width: 640px;
    height: auto;
  }

  .legend {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-faint);
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .swatch {
    width: 18px;
    height: 2px;
    display: inline-block;
  }

  .swatch.structural {
    background: var(--text-faint);
  }

  .swatch.live {
    background: repeating-linear-gradient(
      to right,
      var(--accent-live) 0 4px,
      transparent 4px 7px
    );
  }
</style>
