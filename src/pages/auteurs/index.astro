---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHORS } from "../../lib/author";

const authors = Object.entries(AUTHORS);
---

<BaseLayout title="Auteurs — Le labo de Ludo" description="Qui écrit sur le labo de Ludo.">
  <a class="back" href="/">&larr; tous les articles</a>

  <header class="page-header">
    <h1>Auteurs</h1>
  </header>

  <ul class="authors">
    {
      authors.map(([key, info]) => (
        <li class="author-entry">
          <a class="author-link" href={`/auteurs/${key}/`}>
            <img
              src={info.avatar}
              alt=""
              width="56"
              height="56"
              class:list={[key === "bob" && "bob-blink"]}
            />
            <div>
              <p class="name">{info.name}</p>
              <p class="tagline">{info.tagline}</p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--accent-live);
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
  }

  .authors {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: var(--measure);
    border-top: 1px solid var(--panel-border);
  }

  .author-entry {
    border-bottom: 1px solid var(--panel-border);
  }

  .author-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 0.75rem;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.15s ease;
  }

  .author-link:hover,
  .author-link:focus-visible {
    background: var(--panel);
  }

  .author-link img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.0625rem;
  }

  .tagline {
    margin: 0.35rem 0 0;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
</style>
