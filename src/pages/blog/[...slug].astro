---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryChip from "../../components/CategoryChip.astro";
import AuthorBadge from "../../components/AuthorBadge.astro";
import AuthorLine from "../../components/AuthorLine.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import FrigateDetectorDiagram from "../../components/FrigateDetectorDiagram.astro";
import CloudflareTunnelDiagram from "../../components/CloudflareTunnelDiagram.astro";
import { primaryCategory } from "../../lib/category";
import { authorFromTags } from "../../lib/author";
import { INVENTORY, inventoryForArticle } from "../../lib/inventory";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const category = primaryCategory(post.data.tags);
const author = authorFromTags(post.data.tags);

const englishPosts = await getCollection("blogEn");
const hasEnglish = englishPosts.some((p) => p.id === post.id);
const relatedInventory = inventoryForArticle(post.id);

/** Articles that get an "exploded" architecture-detail diagram, also shown on /architecture/. */
const ARTICLE_DIAGRAMS: Record<string, typeof FrigateDetectorDiagram> = {
  "mon-encodeur-faisait-du-bruit-le-detecteur-video-tournait-sur-le-cpu-au-lieu-du-gpu": FrigateDetectorDiagram,
  "retirer-pare-feu-tunnel-cloudflare": CloudflareTunnelDiagram,
};
const ArticleDiagram = ARTICLE_DIAGRAMS[post.id];
---

<BaseLayout
  title={`${post.data.title} — Le labo de Ludo`}
  description={post.data.description}
  heroImage={post.data.heroImage}
>
  <a class="back" href="/">&larr; tous les articles</a>

  <article>
    <header class="article-header">
      <CategoryChip category={category} />
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("fr-CA", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <AuthorBadge author={author} />
        {hasEnglish && (
          <a class="lang-link" href={`/en/blog/${post.id}/`}>English version</a>
        )}
      </div>
    </header>

    {post.data.heroImage && (
      <img class="hero" src={post.data.heroImage} alt="" />
    )}

    {ArticleDiagram && <ArticleDiagram context="article" />}

    <div class="prose">
      <Content />
    </div>

    {relatedInventory.length > 0 && (
      <aside class="related-inventory">
        <h2>Composants liés</h2>
        <ul>
          {relatedInventory.map((key) => (
            <li><a href={`/inventaire/${key}/`}>{INVENTORY[key].name}</a></li>
          ))}
        </ul>
      </aside>
    )}

    <ShareButtons url={new URL(`/blog/${post.id}/`, Astro.site).toString()} title={post.data.title} lang="fr" />

    <AuthorLine author={author} />
  </article>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--accent-live);
  }

  .article-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0.75rem 0 0.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-faint);
  }

  .hero {
    margin: 2rem 0;
    border: 1px solid var(--panel-border);
    border-radius: 6px;
  }

  .lang-link {
    color: var(--accent-live);
    text-decoration: none;
    margin-left: auto;
  }

  .lang-link:hover {
    text-decoration: underline;
  }

  .related-inventory {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--panel-border);
  }

  .related-inventory h2 {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-faint);
    margin: 0 0 0.75rem;
  }

  .related-inventory ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }

  .related-inventory a {
    display: inline-block;
    padding: 0.3em 0.75em;
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .related-inventory a:hover {
    border-color: var(--accent-live);
    color: var(--accent-live);
  }
</style>
