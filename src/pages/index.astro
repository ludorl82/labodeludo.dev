---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TopologyStrip from "../components/TopologyStrip.astro";
import PostList from "../components/PostList.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Le labo de Ludo"
  description="Journal d'incidents et de bricolages d'un homelab réel — réseau, self-hosting, automatisation."
>
  <TopologyStrip posts={posts} />
  <PostList posts={posts} />
</BaseLayout>
