---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { INVENTORY } from "../../lib/inventory";

const items = Object.entries(INVENTORY);
---

<BaseLayout
  title="Inventaire — Le labo de Ludo"
  description="Liste des machines et rôles du homelab, avec les articles qui en parlent."
>
  <a class="back" href="/">&larr; tous les articles</a>

  <header class="page-header">
    <h1>Inventaire</h1>
    <p class="subtitle">
      Les rôles qui composent le réseau (voir aussi l'<a href="/architecture/">architecture</a>),
      chacun avec sa description et les articles qui en parlent.
    </p>
  </header>

  <ul class="items">
    {
      items.map(([key, item]) => (
        <li class="item-entry">
          <a class="item-link" href={`/inventaire/${key}/`}>
            <div>
              <p class="name">{item.name}</p>
              <p class="description">{item.description}</p>
              {item.articles.length > 0 && (
                <p class="count">
                  {item.articles.length} article{item.articles.length > 1 ? "s" : ""}
                </p>
              )}
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--accent-live);
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }

  .subtitle {
    max-width: var(--measure);
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .subtitle a {
    color: var(--accent-live);
  }

  .items {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: var(--measure);
    border-top: 1px solid var(--panel-border);
  }

  .item-entry {
    border-bottom: 1px solid var(--panel-border);
  }

  .item-link {
    display: block;
    padding: 1.25rem 0.75rem;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.15s ease;
  }

  .item-link:hover {
    background: var(--panel);
  }

  .name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.0625rem;
  }

  .description {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .count {
    margin: 0.5rem 0 0;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
</style>
